# =============================================================================
# foundry-agent-network-diagnostic — deploy settings template
# -----------------------------------------------------------------------------
# Copy this to .env.external.local (gitignored) and fill in your values, then run:
#   bash deploy/deploy.sh         --env-file .env.external.local --what-if
#   bash deploy/deploy.sh         --env-file .env.external.local --scenario lab --yes
#   bash deploy/destroy.sh        --env-file .env.external.local --resource-group rg-agent-net-lab --yes
#   bash deploy/verify-existing.sh --env-file .env.external.local
#
# Do NOT commit tenant-specific values. .env.external.local and .env*.local are gitignored.
# =============================================================================

# --- External tenant login isolation -----------------------------------------
# Use a SEPARATE Azure CLI profile dir so your default/internal `az login` is
# never touched. The script sets AZURE_CONFIG_DIR to this and runs against it.
# Log in once to that profile:
#   AZURE_CONFIG_DIR=~/.azure-agent-net-ext az login --tenant <external-tenant-id>
EXTERNAL_AZURE_CONFIG_DIR=~/.azure-agent-net-ext
EXTERNAL_TENANT_ID=00000000-0000-0000-0000-000000000000

# --- Deployment defaults (CLI flags override these) ---------------------------
SUBSCRIPTION=<subscription-id-or-name>
LOCATION=eastus
SCENARIO=lab
ENV_NAME=agent-net-lab
# RESOURCE_GROUP=rg-agent-net-lab   # optional; defaults to rg-<ENV_NAME>
# NAME_PREFIX=                       # optional; 3-12 lowercase, else auto
# CUSTOM_ZONE=internal.agentlab.example
# CUSTOM_HOST=llm

# --- Safety rails (recommended) -----------------------------------------------
# Deploy aborts unless the active login matches these. Prevents wrong-tenant /
# wrong-subscription deploys.
E2E_EXPECTED_TENANT_ID=00000000-0000-0000-0000-000000000000
E2E_EXPECTED_SUBSCRIPTION_NAME=
